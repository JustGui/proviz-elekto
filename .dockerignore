# ============================================================================
# Security — secrets and credentials (NEVER copy into image)
# ============================================================================
.env
.env.*
!.env.example
*.pem
*.key
*.p12
*.pfx
*.crt
*.cer
*.ca-bundle
*.priv
id_rsa
id_ed25519
id_ecdsa
*.secret
secrets/
credentials/
.netrc
.npmrc
.pypirc

# ============================================================================
# Build artifacts — large and irrelevant to the Docker build
# ============================================================================
target/

# ============================================================================
# Databases — never ship data files
# ============================================================================
*.db
*.db-shm
*.db-wal
*.sqlite
*.sqlite3

# ============================================================================
# Logs
# ============================================================================
*.log
logs/
logs_*.txt

# ============================================================================
# Python
# ============================================================================
__pycache__/
*.py[cod]
*.pyo
.venv/
venv/
dist/
build/
*.egg-info/
*.whl

# ============================================================================
# Git and CI metadata
# ============================================================================
.git/
.github/
.gitignore

# ============================================================================
# Tooling and IDE
# ============================================================================
.claude/
.idea/
.vscode/
*.swp
*.swo
.DS_Store

# ============================================================================
# Documentation and non-runtime assets
# ============================================================================
docs/
examples/
scripts/
README.md
CLAUDE.md
LICENSE
