# ============================================================================
# ProvizElekto - Environment Variables
# Copy to .env and fill in your values.
# ============================================================================

# ---------------------------------------------------------------------------
# Storage backend
# ---------------------------------------------------------------------------
# "sqlite" (default, zero-infra) or "postgres"
PROVIZ_STORAGE=sqlite

# SQLite: path to the database file (used when PROVIZ_STORAGE=sqlite)
PROVIZ_DB_PATH=./proviz.db

# PostgreSQL: full connection URL (used when PROVIZ_STORAGE=postgres)
# Can share an existing database - ProvizElekto uses pz_* prefixed tables.
# PROVIZ_DATABASE_URL=postgresql://user:password@localhost:5432/mydb

# ---------------------------------------------------------------------------
# Server
# ---------------------------------------------------------------------------
# Default: 0 (OS assigns an ephemeral port, printed to stdout as PROVIZ_PORT=<n> on startup).
# Set a fixed value only if you need a stable port (e.g. multi-process setups, firewall rules).
# PROVIZ_PORT=63130

# Rust log level (server binary)
# Options: error | warn | info | debug | trace
RUST_LOG=proviz_server=info,proviz_elekto_core=info

# ---------------------------------------------------------------------------
# Provider API keys
# These are read by YOUR application at call time via candidate.api_key_env.
# ProvizElekto itself never calls LLM APIs - it only tells you which model to use.
# ---------------------------------------------------------------------------
GROQ_API_KEY=gsk_...
MISTRAL_API_KEY=...
OPENAI_API_KEY=sk-...
GEMINI_API_KEY=...
TOGETHER_API_KEY=...
# OLLAMA_BASE_URL=http://localhost:11434  # only needed if non-default
